{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "popolog-pages",
  "compatibility_date": "2026-05-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "popolog.co.kr", "custom_domain": true },
    { "pattern": "www.popolog.co.kr", "custom_domain": true }
  ]
}
